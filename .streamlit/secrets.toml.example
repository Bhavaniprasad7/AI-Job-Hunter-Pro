# For Streamlit Cloud Secrets management
# Copy this file to .streamlit/secrets.toml and fill in your values
# This file should NOT be committed to version control

# OpenAI API Key (required for job matching)
OPENAI_API_KEY = "your-openai-api-key-here"

# Email Configuration (optional)
EMAIL_ENABLED = false
EMAIL_SENDER = "noreply@example.com"
EMAIL_RECIPIENTS = ["your-email@example.com"]
EMAIL_SMTP_SERVER = "smtp.gmail.com"
EMAIL_SMTP_PORT = 587
EMAIL_USERNAME = "your-email@gmail.com"
EMAIL_PASSWORD = "your-app-password"
EMAIL_USE_TLS = true

# Alternative config path (if needed)
# AI_JOB_HUNTER_CONFIG_PATH = "config/config.yaml"
